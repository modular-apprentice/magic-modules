resource "google_bigquery_reservation" "{{$.PrimaryResourceId}}" {
  name           = "{{index $.Vars "name"}}"
  location       = "us-west2"
  // Set to 0 for testing purposes
  // In reality this would be larger than zero
  slot_capacity     = 0
  edition           = "STANDARD"
  ignore_idle_slots = true
  concurrency       = 0
  autoscale {
    max_slots = 100
  }
  reservation_group = "projects/{{index $.TestEnvVars "project"}}/locations/us-west2/reservationGroups/{{index $.Vars "group_name"}}"
}