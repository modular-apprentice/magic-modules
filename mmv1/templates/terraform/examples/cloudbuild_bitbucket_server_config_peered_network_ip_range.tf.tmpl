data "google_project" "project" {}

resource "google_secret_manager_secret" "webhook_secret" {
  secret_id = "{{index $.Vars "webhook_secret_id"}}"
  replication {
    auto {}
  }
}

resource "google_secret_manager_secret_version" "webhook_secret_version" {
  secret = google_secret_manager_secret.webhook_secret.id
  secret_data = "my-secret"
}

resource "google_secret_manager_secret" "read_secret" {
  secret_id = "{{index $.Vars "read_secret_id"}}"
  replication {
    auto {}
  }
}

resource "google_secret_manager_secret_version" "read_secret_version" {
  secret = google_secret_manager_secret.read_secret.id
  secret_data = "my-read-token"
}

resource "google_secret_manager_secret" "admin_secret" {
  secret_id = "{{index $.Vars "admin_secret_id"}}"
  replication {
    auto {}
  }
}

resource "google_secret_manager_secret_version" "admin_secret_version" {
  secret = google_secret_manager_secret.admin_secret.id
  secret_data = "my-admin-token"
}

resource "google_project_service" "servicenetworking" {
  service = "servicenetworking.googleapis.com"
  disable_on_destroy = false
}

resource "google_compute_network" "vpc_network" {
  name       = "{{index $.Vars "network_name"}}"
  depends_on = [google_project_service.servicenetworking]
}

resource "google_compute_global_address" "private_ip_alloc" {
  name          = "{{index $.Vars "global_address_name"}}"
  purpose       = "VPC_PEERING"
  address_type  = "INTERNAL"
  prefix_length = 16
  network       = google_compute_network.vpc_network.id
}

resource "google_service_networking_connection" "default" {
  network                 = google_compute_network.vpc_network.id
  service                 = "servicenetworking.googleapis.com"
  reserved_peering_ranges = [google_compute_global_address.private_ip_alloc.name]
  depends_on              = [google_project_service.servicenetworking]
}

resource "google_cloudbuild_bitbucket_server_config" "{{$.PrimaryResourceId}}" {
  config_id = "{{index $.Vars "config_id"}}"
  location = "us-central1"
  host_uri = "https://bbs.com"
  secrets {
    admin_access_token_version_name = google_secret_manager_secret_version.admin_secret_version.id
    read_access_token_version_name = google_secret_manager_secret_version.read_secret_version.id
    webhook_secret_version_name = google_secret_manager_secret_version.webhook_secret_version.id
  }
  username = "test"
  api_key = "<api-key>"
  peered_network = replace(google_compute_network.vpc_network.id, data.google_project.project.name, data.google_project.project.number)
  peered_network_ip_range = "/29"
  ssl_ca = "-----BEGIN CERTIFICATE-----\n-----END CERTIFICATE-----\n-----BEGIN CERTIFICATE-----\n-----END CERTIFICATE-----\n"
  depends_on = [google_service_networking_connection.default]
}